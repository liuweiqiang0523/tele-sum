{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "src/**/*",
    "plugins/sumplus.prepare.ts",
    "plugins/sumplus.provider.ts",
    "plugins/sumplus.prompts.ts",
    "plugins/sumplus.types.ts"
  ]
}
